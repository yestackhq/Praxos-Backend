# Praxos LMS backend — copy to backend/.env

# Database. Default (unset) uses local SQLite so the app runs with no services.
# For Supabase Postgres, install psycopg ("pip install 'psycopg[binary]'") and set:
# DATABASE_URL=postgresql+psycopg://postgres.ebbgtflhhkrsaadexufg:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
# DATABASE_URL=sqlite:///./praxos_lms.db

SEED_ON_STARTUP=true
CORS_ORIGINS=http://localhost:5173

# Clerk auth. Leave unset for review/dev mode (endpoints open). When set, all
# /api/learner, /api/admin, /api/documents routes require a valid Clerk session JWT.
# CLERK_JWKS_URL=https://<your-subdomain>.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://<your-subdomain>.clerk.accounts.dev
# CLERK_SECRET_KEY=sk_test_...

# OpenAI — document embeddings, voice teaching session, and understanding scoring.
# Without it, uploads still extract/chunk text (no vectors) and voice is disabled.
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_REALTIME_MODEL=gpt-realtime-2
# OPENAI_REALTIME_VOICE=marin

# Original-PDF storage is CLIENT-SIDE (no server key): the browser uploads to
# Supabase Storage with the publishable key. Configure it in web/.env
# (VITE_SUPABASE_URL, VITE_SUPABASE_PUBLISHABLE_KEY, VITE_SUPABASE_BUCKET) and
# create a `documents` bucket with an anon INSERT policy. See README.lms.md.

# HyperMem (helix) — conversation memory. The voice tutor writes each session
# here and reads back a recap so it remembers the learner across chapters.
# Leave unset to run without memory (the tutor just teaches without recall).
# HELIX_URL=https://helixis-testing.up.railway.app
# HELIX_API_KEY=<HYPERMEM_AUTH_ROOT_API_KEY from the helixis Railway service>
# HELIX_TENANT=praxos
